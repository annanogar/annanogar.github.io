{
  "name": "annanogar.github.io",
  "version": "1.0.0",
  "description": "Portfolio of Anna Nogaré",
  "repository": {
    "type": "git",
    "url": "git@github.com:annanogar/annanogar.github.io.git"
  },
  "private": true,
  "main": "./sonic/index.js",
  "type": "module",
  "bin": {
    "sonic": "./sonic/index.js"
  },
  "packageManager": "yarn@4.15.0",
  "scripts": {
    "postinstall": "node sonic --postinstall",
    "start": "node sonic",
    "dev": "node sonic",
    "typecheck": "tsc --noEmit",
    "build": "yarn typecheck && node sonic build",
    "deploy": "node sonic deploy",
    "test:a11y": "playwright test tests/accessibility.spec.js",
    "test:links": "playwright test tests/links.spec.js",
    "test:seo": "playwright test tests/seo.spec.js",
    "test:console": "playwright test tests/console-errors.spec.js",
    "test:bundle-sizes": "size-limit --silent",
    "test": "yarn build && yarn test:a11y && yarn test:links && yarn test:seo && yarn test:console && yarn test:bundle-sizes"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@eklingen/esbuild-browserslist": "1.0.1",
    "@eklingen/file-hash-cache": "1.1.4",
    "@eklingen/glob-importers": "2.1.1",
    "@eklingen/nunjucks-dependencies": "1.0.0",
    "@eslint/js": "10.0.1",
    "@parcel/watcher": "2.5.6",
    "@playwright/test": "1.60.0",
    "@size-limit/file": "12.1.0",
    "autoprefixer": "10.5.0",
    "axe-core": "4.12.0",
    "browserslist": "4.28.2",
    "esbuild": "0.28.0",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.6.0",
    "nunjucks": "3.2.4",
    "postcss": "8.5.15",
    "postcss-scss": "4.0.9",
    "prettier": "3.8.3",
    "prettier-plugin-jinja-template": "2.2.0",
    "sass-embedded": "1.100.0",
    "sharp": "0.34.5",
    "size-limit": "12.1.0",
    "stylelint": "17.12.0",
    "stylelint-config-recommended-scss": "17.0.1",
    "stylelint-config-standard": "40.0.0",
    "stylelint-order": "8.1.1",
    "stylelint-scss": "7.1.1",
    "svgo": "4.0.1",
    "tinyglobby": "0.2.17",
    "typescript": "6.0.3",
    "yazl": "3.3.1"
  },
  "resolutionExplanations": {
    "node-gyp": "linked to null because we don't need it - note: this breaks fs-events and @parcel/watcher (re-)compilation"
  },
  "resolutions": {
    "node-gyp": "link:./node_modules/.null"
  }
}
